@model EventSystemManager.Data.Classes.Registration

@{
    ViewData["Title"] = "Add Registration";
}

<h2>Add Registration</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="EventId" class="form-label">Event</label>
        <select asp-for="EventId" asp-items="ViewBag.Events" class="form-select">
            <option value="">-- Select Event --</option>
        </select>
        <span asp-validation-for="EventId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ParticipantId" class="form-label">Participant</label>
        <select asp-for="ParticipantId" asp-items="ViewBag.Participants" class="form-select">
            <option value="">-- Select Participant --</option>
        </select>
        <span asp-validation-for="ParticipantId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Register</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>