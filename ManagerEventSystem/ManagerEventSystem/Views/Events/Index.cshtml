@model List<EventSystemManager.Data.Classes.Event>

<h2>Events</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Add Event</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>Date</th>
            <th>Location</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var e in Model)
    {
        <tr>
            <td>@e.Title</td>
            <td>@e.Description</td>
            <td>@e.Date</td>
            <td>@e.Location</td>
        </tr>
    }
    </tbody>
</table>