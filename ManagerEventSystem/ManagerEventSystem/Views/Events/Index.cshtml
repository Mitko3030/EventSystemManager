@model List<EventSystemManager.Data.Classes.Event>
@{
    ViewData["Title"] = "Events";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">🎟 Events</h2>
    <a asp-action="Create" class="btn btn-dark">+ Add Event</a>
</div>

<div class="row">
    @foreach (var ev in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                @if (!string.IsNullOrEmpty(ev.ImageUrl))
                {
                    <img src="@ev.ImageUrl" class="card-img-top" style="height:200px; object-fit:cover;" alt="@ev.Title" />
                }
                else
                {
                    <div class="bg-secondary d-flex align-items-center justify-content-center"
                         style="height:200px;">
                        <span style="font-size:60px;">🎫</span>
                    </div>
                }
                <div class="card-body">
                    <h5 class="card-title">@ev.Title</h5>
                    <p class="card-text text-muted">@ev.Description</p>
                    <ul class="list-unstyled small">
                        <li>📅 @ev.Date.ToString("dd MMM yyyy HH:mm")</li>
                        <li>📍 @ev.Location</li>
                        @if (ev.Category != null)
                        {
                            <li>🏷 @ev.Category.Name</li>
                        }
                        @if (ev.Venue != null)
                        {
                            <li>🏟 @ev.Venue.Name</li>
                        }
                    </ul>
                </div>
                <div class="card-footer d-flex justify-content-end">
                    <form asp-action="Delete" asp-route-id="@ev.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-sm"
                                onclick="return confirm('Are you sure you want to delete this event?')">
                             Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center text-muted mt-5">
        <p style="font-size:60px;">📭</p>
        <p>No events yet. Create one!</p>
        <a asp-action="Create" class="btn btn-dark">+ Add Event</a>
    </div>
}